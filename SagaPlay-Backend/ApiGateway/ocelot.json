{
  "Routes": [
    {
      "DownstreamPathTemplate": "/api/user-service/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "user-service",
          "Port": 8080
        }
      ],
      "UpstreamPathTemplate": "/userservice/{everything}",
      "AuthenticationOptions": {
        "AuthenticationProviderKey": "Okta",
        "AllowedScopes": []
      },
      "UpstreamHttpMethod": [ "GET", "POST", "PUT", "DELETE" ]
    },
    {
      "DownstreamPathTemplate": "/api/user-service/register",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "user-service",
          "Port": 8080
        }
      ],
      "UpstreamPathTemplate": "/userservice/register",
      "UpstreamHttpMethod": [ "POST" ]
